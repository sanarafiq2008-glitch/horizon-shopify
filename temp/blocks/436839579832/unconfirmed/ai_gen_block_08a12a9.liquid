{% doc %}
  @prompt
    marque effect on announcement bar
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-announcement-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding: 0 {{ block.settings.item_spacing }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  {% if block.settings.text_transform == 'uppercase' %}
    .ai-marquee-content-{{ ai_gen_id }} {
      text-transform: uppercase;
    }
  {% endif %}

  .ai-marquee-separator-{{ ai_gen_id }} {
    display: inline-block;
    margin: 0 {{ block.settings.separator_spacing }}px;
    {% if block.settings.separator_type == 'dot' %}
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background-color: {{ block.settings.text_color }};
    {% elsif block.settings.separator_type == 'star' %}
      font-size: {{ block.settings.font_size }}px;
    {% elsif block.settings.separator_type == 'dash' %}
      width: 20px;
      height: 2px;
      background-color: {{ block.settings.text_color }};
    {% endif %}
  }

  .ai-marquee-announcement-{{ ai_gen_id }}:hover .ai-marquee-track-{{ ai_gen_id }} {
    {% if block.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<marquee-announcement-{{ ai_gen_id }} class="ai-marquee-announcement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-track-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      <div class="ai-marquee-content-{{ ai_gen_id }}">
        {% if block.settings.announcement_text != blank %}
          {{ block.settings.announcement_text }}
        {% else %}
          Announce something here
        {% endif %}
        
        {% if block.settings.show_separator %}
          <span class="ai-marquee-separator-{{ ai_gen_id }}">
            {% if block.settings.separator_type == 'star' %}
              ★
            {% elsif block.settings.separator_type == 'dot' %}
            {% elsif block.settings.separator_type == 'dash' %}
            {% endif %}
          </span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</marquee-announcement-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeAnnouncement{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-marquee-track-{{ ai_gen_id }}');
        this.adjustSpeed();
      }

      adjustSpeed() {
        if (!this.track) return;
        
        const trackWidth = this.track.scrollWidth / 2;
        const speed = {{ block.settings.scroll_speed }};
        const duration = (trackWidth / 100) * speed;
        
        this.track.style.animationDuration = duration + 's';
      }
    }

    customElements.define('marquee-announcement-{{ ai_gen_id }}', MarqueeAnnouncement{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Marquee announcement",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Welcome to our store! Free shipping on orders over $50"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Lower is faster"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "select",
      "id": "separator_type",
      "label": "Separator type",
      "options": [
        {
          "value": "dot",
          "label": "Dot"
        },
        {
          "value": "star",
          "label": "Star"
        },
        {
          "value": "dash",
          "label": "Dash"
        }
      ],
      "default": "star"
    },
    {
      "type": "range",
      "id": "separator_spacing",
      "label": "Separator spacing",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ff6b35"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 3,
      "step": 0.5,
      "unit": "px",
      "default": 0.5
    }
  ],
  "presets": [
    {
      "name": "Marquee announcement"
    }
  ]
}
{% endschema %}
