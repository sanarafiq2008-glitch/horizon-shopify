{% doc %}
  @prompt
    header
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    position: {{ block.settings.position }};
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
  }

  .ai-header-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-header-logo-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: {{ block.settings.text_color }};
  }

  .ai-header-logo-image-{{ ai_gen_id }} {
    height: {{ block.settings.logo_height }}px;
    width: auto;
  }

  .ai-header-logo-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_text_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-header-nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.nav_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-header-nav-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.nav_text_size }}px;
    transition: color 0.3s ease;
  }

  .ai-header-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-header-actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.action_spacing }}px;
  }

  .ai-header-action-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.text_color }};
    transition: color 0.3s ease;
  }

  .ai-header-action-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-header-action-button-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-header-mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-header-mobile-toggle-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-header-nav-{{ ai_gen_id }} {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: {{ block.settings.background_color }};
      flex-direction: column;
      align-items: flex-start;
      padding: 20px;
      border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    }

    .ai-header-nav-{{ ai_gen_id }}.active {
      display: flex;
    }

    .ai-header-mobile-toggle-{{ ai_gen_id }} {
      display: flex;
    }

    .ai-header-logo-image-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height_mobile }}px;
    }

    .ai-header-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<header-component-{{ ai_gen_id }} class="ai-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-header-container-{{ ai_gen_id }}">
    <a href="{{ block.settings.logo_link }}" class="ai-header-logo-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 400 }}"
          alt="{{ shop.name }}"
          class="ai-header-logo-image-{{ ai_gen_id }}"
          width="400"
          height="{{ block.settings.logo.height | times: 400 | divided_by: block.settings.logo.width }}"
          loading="lazy"
        >
      {% else %}
        <h1 class="ai-header-logo-text-{{ ai_gen_id }}">{{ block.settings.logo_text }}</h1>
      {% endif %}
    </a>

    {% if block.settings.show_navigation %}
      <nav>
        <ul class="ai-header-nav-{{ ai_gen_id }}" id="ai-header-nav-{{ ai_gen_id }}">
          {% if block.settings.nav_link_1_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_1_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_1_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.nav_link_2_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_2_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_2_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.nav_link_3_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_3_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_3_text }}
              </a>
            </li>
          {% endif %}
          {% if block.settings.nav_link_4_text != blank %}
            <li>
              <a href="{{ block.settings.nav_link_4_url }}" class="ai-header-nav-link-{{ ai_gen_id }}">
                {{ block.settings.nav_link_4_text }}
              </a>
            </li>
          {% endif %}
        </ul>
      </nav>
    {% endif %}

    <div class="ai-header-actions-{{ ai_gen_id }}">
      {% if block.settings.show_search %}
        <a href="/search" class="ai-header-action-button-{{ ai_gen_id }}" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>
      {% endif %}

      {% if block.settings.show_account %}
        <a href="/account" class="ai-header-action-button-{{ ai_gen_id }}" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </a>
      {% endif %}

      {% if block.settings.show_cart %}
        <a href="/cart" class="ai-header-action-button-{{ ai_gen_id }}" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </a>
      {% endif %}

      {% if block.settings.show_navigation %}
        <button
          class="ai-header-mobile-toggle-{{ ai_gen_id }}"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="ai-header-nav-{{ ai_gen_id }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      {% endif %}
    </div>
  </div>
</header-component-{{ ai_gen_id }}>

<script>
  (function() {
    class HeaderComponent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.mobileToggle = this.querySelector('.ai-header-mobile-toggle-{{ ai_gen_id }}');
        this.nav = this.querySelector('.ai-header-nav-{{ ai_gen_id }}');

        if (this.mobileToggle && this.nav) {
          this.mobileToggle.addEventListener('click', this.toggleMobileMenu.bind(this));
        }
      }

      toggleMobileMenu() {
        const isExpanded = this.mobileToggle.getAttribute('aria-expanded') === 'true';
        this.mobileToggle.setAttribute('aria-expanded', !isExpanded);
        this.nav.classList.toggle('active');
      }
    }

    customElements.define('header-component-{{ ai_gen_id }}', HeaderComponent{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Header",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
