{% doc %}
  @prompt
    Create a collection slider/carousel section that displays collections in a horizontal scrollable slider style with navigation arrows and smooth sliding animation. Each slide should show the collection's featured image, collection title, and a link to the collection page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-collection-slider-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-slider-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }

  .ai-collection-slider-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-collection-slider-nav-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
  }

  .ai-collection-slider-nav-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_background }};
    border: 1px solid {{ block.settings.arrow_border }};
    color: {{ block.settings.arrow_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-collection-slider-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
  }

  .ai-collection-slider-nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collection-slider-nav-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-collection-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-collection-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-collection-slider-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.slides_per_view | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.slides_per_view }});
    min-width: 0;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: 100%;
  }

  .ai-collection-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover .ai-collection-card-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-card-image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
  }

  .ai-collection-card-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-collection-empty-state-{{ ai_gen_id }} p {
    margin: 0;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-slider-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_per_view_tablet | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.slides_per_view_tablet }});
    }

    .ai-collection-slider-header-{{ ai_gen_id }} {
      margin-bottom: 24px;
    }

    .ai-collection-slider-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-slider-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.slides_per_view_mobile | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.slides_per_view_mobile }});
    }

    .ai-collection-slider-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-collection-slider-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }
  }
{% endstyle %}

<collection-slider-{{ ai_gen_id }} class="ai-collection-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-slider-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-collection-slider-header-{{ ai_gen_id }}">
        <h2 class="ai-collection-slider-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        <div class="ai-collection-slider-nav-{{ ai_gen_id }}">
          <button
            class="ai-collection-slider-nav-button-{{ ai_gen_id }} ai-collection-slider-prev-{{ ai_gen_id }}"
            aria-label="Previous slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button
            class="ai-collection-slider-nav-button-{{ ai_gen_id }} ai-collection-slider-next-{{ ai_gen_id }}"
            aria-label="Next slide"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </div>
    {% endif %}

    {% if block.settings.collections != blank %}
      <div class="ai-collection-slider-wrapper-{{ ai_gen_id }}">
        <div class="ai-collection-slider-track-{{ ai_gen_id }}">
          {% for collection in block.settings.collections %}
            <div class="ai-collection-slider-slide-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-collection-card-{{ ai_gen_id }}">
                <div class="ai-collection-card-image-wrapper-{{ ai_gen_id }}">
                  {% if collection.featured_image %}
                    <img
                      src="{{ collection.featured_image | image_url: width: 800 }}"
                      alt="{{ collection.featured_image.alt | escape }}"
                      loading="lazy"
                      width="800"
                      height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                      class="ai-collection-card-image-{{ ai_gen_id }}"
                    >
                  {% else %}
                    {{ 'collection-1' | placeholder_svg_tag }}
                  {% endif %}
                </div>
                {% if block.settings.show_title %}
                  <div class="ai-collection-card-content-{{ ai_gen_id }}">
                    <h3 class="ai-collection-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                  </div>
                {% endif %}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="ai-collection-empty-state-{{ ai_gen_id }}">
        <p>Select collections to display in the slider</p>
      </div>
    {% endif %}
  </div>
</collection-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.slidesPerView = {{ block.settings.slides_per_view }};
        this.slidesPerViewTablet = {{ block.settings.slides_per_view_tablet }};
        this.slidesPerViewMobile = {{ block.settings.slides_per_view_mobile }};
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-collection-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-collection-slider-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-collection-slider-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-collection-slider-next-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.setupEventListeners();
        this.updateButtons();
        this.setupTouchEvents();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }

        window.addEventListener('resize', () => this.updateButtons());
      }

      setupTouchEvents() {
        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;

          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.next();
            } else {
              this.prev();
            }
          }
        });
      }

      getCurrentSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) return this.slidesPerViewMobile;
        if (width <= 989) return this.slidesPerViewTablet;
        return this.slidesPerView;
      }

      getMaxIndex() {
        return Math.max(0, this.slides.length - this.getCurrentSlidesPerView());
      }

      prev() {
        this.currentIndex = Math.max(0, this.currentIndex - 1);
        this.updateSlider();
      }

      next() {
        this.currentIndex = Math.min(this.getMaxIndex(), this.currentIndex + 1);
        this.updateSlider();
      }

      updateSlider() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = this.currentIndex * (slideWidth + gap);
        
        this.track.style.transform = `translateX(-${offset}px)`;
        this.updateButtons();
      }

      updateButtons() {
        if (!this.prevButton || !this.nextButton) return;

        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= this.getMaxIndex();
      }
    }

    customElements.define('collection-slider-{{ ai_gen_id }}', CollectionSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection slider",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection titles",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "slides_per_view",
      "label": "Slides per view (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_per_view_tablet",
      "label": "Slides per view (tablet)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "Slides per view (mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_border",
      "label": "Arrow border",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_hover_background",
      "label": "Arrow hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_hover_color",
      "label": "Arrow hover color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
